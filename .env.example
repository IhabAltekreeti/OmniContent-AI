# Copy this file to .env and fill in your own API keys.
# Never commit the real .env file — it's already excluded via .gitignore.

# Get your key at: https://openrouter.ai/keys
OPENROUTER_KEY=your_openrouter_key_here

# Get your key at: https://www.pexels.com/api/
PEXELS_KEY=your_pexels_key_here

# Get your authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_TOKEN=your_ngrok_authtoken_here

# Local Flask server port
PORT=5005
